<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #82c0f2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.InventoryadminController">

    
    <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">

        
        <HBox alignment="CENTER" spacing="20.0">
         
            <StackPane prefHeight="80" prefWidth="200" style="-fx-background-color: #2196F3; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER" spacing="5">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Total Products" />
                    <Label fx:id="totalProductsLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="0" />
                </VBox>
            </StackPane>

         
            <StackPane prefHeight="80" prefWidth="200" style="-fx-background-color: #FF9800; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER" spacing="5">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Low Stock Items" />
                    <Label fx:id="lowStockLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="0" />
                </VBox>
            </StackPane>

         
            <StackPane prefHeight="80" prefWidth="200" style="-fx-background-color: #F44336; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER" spacing="5">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Out of Stock" />
                    <Label fx:id="outOfStockLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="0" />
                </VBox>
            </StackPane>
        </HBox>

      
        <TextField fx:id="searchField" prefWidth="600" promptText="Search..." />

       
        <TableView fx:id="inventoryTable" prefHeight="300" prefWidth="780" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="100" text="ID" />
                <TableColumn fx:id="nameColumn" prefWidth="300" text="Product Name" />
                <TableColumn fx:id="categoryColumn" prefWidth="150" text="Category" />
                <TableColumn fx:id="quantityColumn" prefWidth="107.0" text="Quantity" />
                <TableColumn fx:id="priceColumn" prefWidth="143.0" text="Price" />
            </columns>
        </TableView>


        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="addButton" prefWidth="150" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Add Product" />
            <Button fx:id="editButton" prefWidth="150" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="Edit Product" />
            <Button fx:id="deleteButton" prefWidth="150" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-weight: bold;" text="Delete Product" />
        </HBox>

    </VBox>

</AnchorPane>
