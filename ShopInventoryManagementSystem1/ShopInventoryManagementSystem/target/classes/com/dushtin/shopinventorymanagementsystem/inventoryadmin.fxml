<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="module-page" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.InventoryadminController">

    <VBox alignment="TOP_CENTER" spacing="20.0" styleClass="module-body" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">

        <HBox alignment="CENTER" spacing="20.0">

            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-blue">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Total Products" styleClass="card-label"/>
                    <Label fx:id="totalProductsLabel" text="0" styleClass="card-value"/>
                </VBox>
            </StackPane>

            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-orange">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Low Stock Items" styleClass="card-label"/>
                    <Label fx:id="lowStockLabel" text="0" styleClass="card-value"/>
                </VBox>
            </StackPane>

            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-red">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Out of Stock" styleClass="card-label"/>
                    <Label fx:id="outOfStockLabel" text="0" styleClass="card-value"/>
                </VBox>
            </StackPane>

        </HBox>

        <TextField fx:id="searchField" prefHeight="45.0" prefWidth="780.0" promptText="Search..." styleClass="search-field"/>

        <VBox prefWidth="780.0" styleClass="table-card panel-card">
            <TableView fx:id="inventoryTable" prefHeight="300.0" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="90.0" text="ID"/>
                    <TableColumn fx:id="nameColumn" prefWidth="260.0" text="Product Name"/>
                    <TableColumn fx:id="categoryColumn" prefWidth="150.0" text="Category"/>
                    <TableColumn fx:id="quantityColumn" prefWidth="120.0" text="Quantity"/>
                    <TableColumn fx:id="priceColumn" prefWidth="140.0" text="Price"/>
                </columns>
            </TableView>
        </VBox>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="addButton" prefHeight="45.0" prefWidth="150.0" text="Add Product" styleClass="btn-success"/>
            <Button fx:id="editButton" prefHeight="45.0" prefWidth="150.0" text="Edit Product" styleClass="btn-primary"/>
            <Button fx:id="deleteButton" prefHeight="45.0" prefWidth="150.0" text="Delete Product" styleClass="btn-danger"/>
        </HBox>

    </VBox>

</AnchorPane>
