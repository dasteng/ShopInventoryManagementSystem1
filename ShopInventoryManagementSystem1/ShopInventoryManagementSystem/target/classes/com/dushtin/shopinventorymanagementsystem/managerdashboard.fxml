<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="800" style="-fx-background-color: #f5f7fa;" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.dushtin.shopinventorymanagementsystem.AdmindashboardController"
            stylesheets="@CSS.css">

    <top>
        <BorderPane prefHeight="40" style="-fx-padding: 5px; -fx-background-color: #FFFFFF;">
            <left>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="burgerButton" text="☰" 
                            style="-fx-background-color: transparent; -fx-text-fill: black; -fx-font-size: 15px; -fx-cursor: hand;" />
                    <Label text="Manager" 
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                </HBox>
            </left>
        </BorderPane>
    </top>

    <left>
        <VBox fx:id="sidebar" prefWidth="250" spacing="5"
      style="-fx-background-color: #3b6ea8; -fx-padding: 20; -fx-alignment: TOP_CENTER;"
      visible="false" managed="false">
    <Button fx:id="homeButton" text="Dashboard" styleClass="sidebar-button" />
    <Button fx:id="buttonInventory" text="Inventory" styleClass="sidebar-button" />
    <Button fx:id="buttonSalesRecording" text="Sales" styleClass="sidebar-button" />
    <Button fx:id="buttonStockMonitoring" text="Stock Monitoring" styleClass="sidebar-button" />
    <Button fx:id="buttonReporting" text="Reports" styleClass="sidebar-button" />
    <Button fx:id="logoutButton" text="Logout" styleClass="sidebar-button" />
</VBox>


    </left>

    <center>
        <StackPane fx:id="Centerpane" style="-fx-background-color: #f0f2ff;" />
    </center>

</BorderPane>
