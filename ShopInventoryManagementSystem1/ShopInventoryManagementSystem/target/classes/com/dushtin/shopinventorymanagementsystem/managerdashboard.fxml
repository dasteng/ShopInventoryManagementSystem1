<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="800" style="-fx-background-color: #f5f7fa;" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.ManagerdashboardController">

    <top>
        <BorderPane prefHeight="50.0" prefWidth="800.0" style="-fx-padding: 5px; -fx-background-color: #3b6ea8;">
            <left>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="burgerButton" prefHeight="41.0" prefWidth="75.0" style="-fx-background-color: transparent; -fx-text-fill: black; -fx-font-size: 15px; -fx-cursor: hand;" text="☰" textFill="#390101" />
                    <Label prefHeight="32.0" prefWidth="107.0" style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Manager" />
                </HBox>
            </left>
        </BorderPane>
    </top>

    <left>
        <VBox fx:id="sidebar" managed="false" prefWidth="250" spacing="5" style="-fx-background-color: #3b6ea8; -fx-padding: 20; -fx-alignment: TOP_CENTER;" visible="false">
    <!--<Button fx:id="homeButton" styleClass="sidebar-button" text="Dashboard" />-->
    <Button fx:id="buttonInventory" styleClass="sidebar-button" text="Inventory" />
    <Button fx:id="buttonSalesRecording" styleClass="sidebar-button" text="Sales" />
    <Button fx:id="buttonStockMonitoring" styleClass="sidebar-button" text="Stock Monitoring" />
    <!--<Button fx:id="buttonReporting" styleClass="sidebar-button" text="Reports" /> -->
    <Region VBox.vgrow="ALWAYS" />

    <Button fx:id="logoutButton" style="-fx-background-color: #e74c3c; -fx-text-fill: white; " styleClass="sidebar-button" text="Logout" />
</VBox>


    </left>

    <center>
        <StackPane fx:id="Centerpane" style="-fx-background-color: #f0f2ff;" />
    </center>

</BorderPane>
