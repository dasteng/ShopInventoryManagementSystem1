<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1240.0" styleClass="dashboard-root" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.ManagerdashboardController">

    <top>
        <BorderPane prefHeight="86.0" prefWidth="1240.0" styleClass="topbar">
            <left>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="topbar-section">
                    <Button fx:id="burgerButton" prefHeight="42.0" prefWidth="92.0" styleClass="menu-button" text="Menu" />
                    <VBox spacing="2.0">
                        <Label text="Shop Inventory" styleClass="topbar-kicker" />
                        <Label text="Manager Dashboard" styleClass="topbar-title" />
                    </VBox>
                </HBox>
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="topbar-section">
                    <VBox alignment="CENTER_RIGHT" spacing="2.0">
                        <Label text="Manager" styleClass="account-name" />
                    </VBox>
                    <StackPane prefHeight="46.0" prefWidth="46.0" styleClass="avatar-badge">
                        <Label text="MG" styleClass="avatar-text" />
                    </StackPane>
                </HBox>
            </right>
        </BorderPane>
    </top>

    <left>
        <VBox fx:id="sidebar" managed="false" prefWidth="270.0" spacing="12.0" styleClass="sidebar-panel" visible="false">
    <VBox spacing="4.0" styleClass="sidebar-brand">
      
    
    </VBox>
    <!--<Button fx:id="homeButton" styleClass="sidebar-button" text="Dashboard" />-->
    <Button fx:id="buttonInventory" styleClass="sidebar-button" text="Inventory" />
    <Button fx:id="buttonSalesRecording" styleClass="sidebar-button" text="Sales" />
    <Button fx:id="buttonStockMonitoring" styleClass="sidebar-button" text="Stock Monitoring" />
    <!--<Button fx:id="buttonReporting" styleClass="sidebar-button" text="Reports" /> -->
    <Region VBox.vgrow="ALWAYS" />

    <Button fx:id="logoutButton" styleClass="sidebar-button, logout-button" text="Logout" />
</VBox>


    </left>

    <center>
        <StackPane fx:id="Centerpane" styleClass="content-shell" />
    </center>

</BorderPane>
