            <?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>


<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #82c0f2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.SalesrecordingadminController">
    <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">

        
        <HBox alignment="CENTER" spacing="20.0">
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #2196F3; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER">
                    <Label text="Total Sales" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="totalSalesLabel" text="₱0.00" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #4CAF50; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label text="Total Profit" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="totalProfitLabel" text="₱0.00" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #FF9800; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label text="Transactions Today" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="transactionsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
        </HBox>

        
        <TextField fx:id="searchField" prefWidth="600" promptText="Search by Product or ID..." />

       
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Record Sale:" style="-fx-font-weight: bold; -fx-text-fill: white;" />
            <ComboBox fx:id="productComboBox" prefWidth="150" />
            <Label text="Current Stock:" style="-fx-text-fill: white;" />
            <Label fx:id="currentStockLabel" text="0" style="-fx-text-fill: white; -fx-font-weight: bold;" />
            <Button fx:id="addSaleBtn" text="Add Sale" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>

        
        <TableView fx:id="salesTable" prefHeight="300" prefWidth="780" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="saleIdColumn" prefWidth="100" text="Sale ID" />
                <TableColumn fx:id="productNameColumn" prefWidth="300" text="Product Name" />
                <TableColumn fx:id="quantitySoldColumn" prefWidth="100" text="Quantity" />
                <TableColumn fx:id="priceColumn" prefWidth="150" text="Price" />
                <TableColumn fx:id="totalColumn" prefWidth="150" text="Total" />
            </columns>
        </TableView>

    </VBox>
</AnchorPane>