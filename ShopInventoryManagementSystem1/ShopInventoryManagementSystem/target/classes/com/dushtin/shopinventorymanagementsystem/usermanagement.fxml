<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="module-body"
      stylesheets="@CSS.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.dushtin.shopinventorymanagementsystem.UsermanagementController">

    <Label text="User Management" style="-fx-font-weight: bold; -fx-text-fill: #0f172a;">
        <font><Font name="Century Gothic" size="28.0" /></font>
    </Label>

    <VBox styleClass="table-card panel-card">
        <TableView fx:id="usersTable" prefHeight="220.0" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50.0" />
                <TableColumn fx:id="colUsername" text="Username" prefWidth="200.0" />
                <TableColumn fx:id="colRole" text="Role" prefWidth="150.0" />
            </columns>
        </TableView>
    </VBox>

    <HBox spacing="10.0">
        <Button text="Change Password" onAction="#handleChangePassword"
                styleClass="btn-primary" />
        <Button text="Delete User" onAction="#handleDeleteUser"
                styleClass="btn-danger" />
    </HBox>

    <Separator />

    <Label text="Add New User" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #021839;" />

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="newUsernameField" promptText="Username" style="-fx-prompt-text-fill: gray;" prefWidth="180.0" styleClass="search-field" />
        <PasswordField fx:id="newPasswordField" promptText="Password" style="-fx-prompt-text-fill: gray;" prefWidth="180.0" styleClass="search-field" />
        <ComboBox fx:id="newRoleCombo" prefWidth="130.0" />
        <Button text="Add User" onAction="#handleAddUser"
                styleClass="btn-success" />
    </HBox>

    <Label fx:id="messageLabel" text="" />

</VBox>
