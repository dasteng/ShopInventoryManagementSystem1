<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>


<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #82c0f2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.StockmonitoringadminController">
    <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">

        <HBox alignment="CENTER" spacing="20.0">
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #2196F3; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER">
                    <Label text="Total Products" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="totalProductsLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #FF9800; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label text="Low Stock Items" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="lowStockLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
            <StackPane prefWidth="200" prefHeight="80" style="-fx-background-color: #F44336; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label text="Out of Stock" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label fx:id="outOfStockLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                </VBox>
            </StackPane>
        </HBox>


        <TextField fx:id="searchField" prefWidth="600" promptText="Search product..." />
       
        <TableView fx:id="stockTable" prefHeight="400" prefWidth="780" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="nameproductColumn" prefWidth="300" text="Product Name" />
                <TableColumn fx:id="quantityColumn" prefWidth="300" text="Quantity" />
                <TableColumn fx:id="statusColumn" prefWidth="300" text="Status" />

            </columns>
        </TableView>

    </VBox>
</AnchorPane>