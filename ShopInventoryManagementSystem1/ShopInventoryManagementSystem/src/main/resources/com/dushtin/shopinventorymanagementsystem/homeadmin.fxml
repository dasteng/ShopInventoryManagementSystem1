<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="800.0" styleClass="module-page" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.HomeController">

    <VBox alignment="TOP_LEFT" spacing="24.0" styleClass="module-body" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="16.0" AnchorPane.rightAnchor="16.0" AnchorPane.topAnchor="16.0">
        <Text fill="#0f172a" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-weight: bold;" text="Dashboard" wrappingWidth="655.13671875">
            <font>
                <Font name="Century Gothic" size="42.0" />
            </font>
        </Text>

        <HBox alignment="CENTER" prefHeight="180.0" prefWidth="780.0" spacing="18.0">
            <children>
                <StackPane prefHeight="180.0" prefWidth="245.0" styleClass="dashboard-card-blue">
                    <VBox alignment="CENTER_LEFT" spacing="12.0" maxWidth="190.0">
                        <Label text="Total Transactions" styleClass="dashboard-card-label">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <Label fx:id="totalTransactionsLabel" text="0" styleClass="dashboard-card-value">
                            <font><Font size="44.0" /></font>
                        </Label>
                    </VBox>
                </StackPane>

                <StackPane prefHeight="180.0" prefWidth="245.0" styleClass="dashboard-card-indigo">
                    <VBox alignment="CENTER_LEFT" spacing="12.0" maxWidth="190.0">
                        <Label text="Total Items Sold" styleClass="dashboard-card-label">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <Label fx:id="totalItemsSoldLabel" text="0" styleClass="dashboard-card-value">
                            <font><Font size="44.0" /></font>
                        </Label>
                    </VBox>
                </StackPane>

                <StackPane prefHeight="180.0" prefWidth="245.0" styleClass="dashboard-card-green">
                    <VBox alignment="CENTER_LEFT" spacing="12.0" maxWidth="190.0">
                        <Label text="Total Profit" styleClass="dashboard-card-label">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <Label fx:id="totalProfitLabel" text="0" styleClass="dashboard-card-value">
                            <font><Font size="38.0" /></font>
                        </Label>
                    </VBox>
                </StackPane>
            </children>
        </HBox>

        <HBox alignment="CENTER" prefHeight="180.0" prefWidth="780.0" spacing="18.0">
            <children>
                <StackPane prefHeight="180.0" prefWidth="380.0" styleClass="dashboard-card-indigo">
                    <VBox alignment="CENTER_LEFT" spacing="12.0" maxWidth="280.0">
                        <Label text="Total Stocks" styleClass="dashboard-card-label">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <Label fx:id="totalStocksLabel" text="0" styleClass="dashboard-card-value">
                            <font><Font size="44.0" /></font>
                        </Label>
                    </VBox>
                </StackPane>

                <StackPane prefHeight="180.0" prefWidth="380.0" styleClass="dashboard-card-blue">
                    <VBox alignment="CENTER_LEFT" spacing="12.0" maxWidth="280.0">
                        <Label text="Total Products" styleClass="dashboard-card-label">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <Label fx:id="totalProductsLabel" text="0" styleClass="dashboard-card-value">
                            <font><Font size="44.0" /></font>
                        </Label>
                    </VBox>
                </StackPane>
            </children>
        </HBox>

    </VBox>

</AnchorPane>
