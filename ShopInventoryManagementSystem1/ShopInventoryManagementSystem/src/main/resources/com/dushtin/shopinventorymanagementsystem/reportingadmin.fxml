<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<!-- suggest more necessary things nalang tol
-->

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="module-page" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.ReportingadminController">

<VBox alignment="TOP_CENTER" spacing="16.0" styleClass="module-body" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">

    
    <Label styleClass="report-heading" text="Inventory Status" />

    <VBox prefWidth="780.0" styleClass="table-card panel-card">
        <TableView fx:id="inventoryReportTable" prefHeight="140.0" prefWidth="780.0" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="invProductCol" prefWidth="250.0" text="Product" />
                <TableColumn fx:id="invCategoryCol" prefWidth="180.0" text="Category" />
                <TableColumn fx:id="invStockCol" prefWidth="150.0" text="Stock" />
                <TableColumn fx:id="invValueCol" prefWidth="200.0" text="Value" />
            </columns>
        </TableView>
    </VBox>

    <Label fx:id="totalInventoryValueLabel" styleClass="report-total" text="Total Inventory Value: 0.00" />

    
    <Label styleClass="report-heading" text="Sales Summary" />

    <VBox prefWidth="780.0" styleClass="table-card panel-card">
        <TableView fx:id="salesReportTable" prefHeight="140.0" prefWidth="780.0" styleClass="modern-table">
            <columns>
                <TableColumn prefWidth="100.0" text="Sale ID" />
                <TableColumn prefWidth="250.0" text="Product" />
                <TableColumn prefWidth="150.0" text="Quantity" />
                <TableColumn prefWidth="200.0" text="Total Profit" />
            </columns>
        </TableView>
    </VBox>

    
    <Label styleClass="report-heading" text="Low Stock Alert" />

    <VBox prefWidth="780.0" styleClass="table-card panel-card">
        <TableView fx:id="lowStockTable" prefHeight="140.0" prefWidth="780.0" styleClass="modern-table">
            <columns>
                <TableColumn prefWidth="400.0" text="Low Stock Product" />
                <TableColumn prefWidth="200.0" text="Remaining Quantity" />
            </columns>
        </TableView>
    </VBox>

</VBox>
</AnchorPane>
