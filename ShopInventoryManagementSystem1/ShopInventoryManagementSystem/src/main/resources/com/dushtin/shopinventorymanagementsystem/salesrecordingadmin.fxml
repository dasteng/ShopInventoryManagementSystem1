<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #82c0f2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.SalesrecordingadminController">
    <VBox alignment="TOP_CENTER" spacing="15.0" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">

        
        <HBox alignment="CENTER" spacing="20.0">
            <StackPane prefHeight="90" prefWidth="200" style="-fx-background-color: #2196F3; -fx-background-radius: 10; -fx-padding: 10;">
                <VBox alignment="CENTER">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Today's Sales">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="totalSalesLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="₱0.00">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
            <StackPane prefHeight="90" prefWidth="200" style="-fx-background-color: #4CAF50; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Total Profit">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="totalProfitLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="₱0.00">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
            <StackPane prefHeight="90" prefWidth="200" style="-fx-background-color: #FF9800; -fx-background-radius: 10;">
                <VBox alignment="CENTER">
                    <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Transactions Today">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="transactionsLabel" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="0">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
        </HBox>

        
        <TextField fx:id="searchField" prefHeight="50.0" prefWidth="780.0" promptText="Search by Product or ID..." />

       
        <HBox alignment="CENTER" prefHeight="35.0" prefWidth="780.0" spacing="10.0">
            <Label style="-fx-font-weight: bold; -fx-text-fill: white;" text="Record Sale:" />
            <ComboBox fx:id="productComboBox" prefWidth="150" />
            <Label style="-fx-text-fill: white;" text="Current Stock:" />
            <Label fx:id="currentStockLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="0" />
            <Button fx:id="addSaleBtn" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Add Sale" />
        </HBox>

        
        <TableView fx:id="salesTable" prefHeight="300" prefWidth="780" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="saleIdColumn" prefWidth="100" text="Sale ID" />
                <TableColumn fx:id="productNameColumn" prefWidth="300" text="Product Name" />
                <TableColumn fx:id="quantitySoldColumn" prefWidth="100" text="Quantity" />
                <TableColumn fx:id="priceColumn" prefWidth="150" text="Price" />
                <TableColumn fx:id="totalColumn" prefWidth="150" text="Total" />
            </columns>
        </TableView>

    </VBox>
</AnchorPane>
