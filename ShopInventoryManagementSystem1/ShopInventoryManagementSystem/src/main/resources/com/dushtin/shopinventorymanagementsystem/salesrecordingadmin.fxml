<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="module-page" stylesheets="@CSS.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dushtin.shopinventorymanagementsystem.SalesrecordingadminController">
    <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="module-body" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">

        
        <HBox alignment="CENTER" spacing="20.0">
            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-blue">
                <VBox alignment="CENTER">
                    <Label styleClass="card-label" text="Today's Sales">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="totalSalesLabel" styleClass="card-value" text="0.00">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-green">
                <VBox alignment="CENTER">
                    <Label styleClass="card-label" text="Total Profit">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="totalProfitLabel" styleClass="card-value" text="0.00">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
            <StackPane prefHeight="96.0" prefWidth="200.0" styleClass="metric-card-orange">
                <VBox alignment="CENTER">
                    <Label styleClass="card-label" text="Transactions Today">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                    <Label fx:id="transactionsLabel" styleClass="card-value" text="0">
                  <font>
                     <Font size="14.0" />
                  </font></Label>
                </VBox>
            </StackPane>
        </HBox>

        
        <TextField fx:id="searchField" prefHeight="50.0" prefWidth="780.0" promptText="Search by Product or ID..." style="-fx-prompt-text-fill: gray;" styleClass="search-field" />

       
        <HBox alignment="CENTER" prefHeight="54.0" prefWidth="780.0" spacing="10.0" styleClass="toolbar-row">
            <Label styleClass="toolbar-label" text="Record Sale:" />
            <ComboBox fx:id="productComboBox" prefWidth="150.0" />
            <Label styleClass="toolbar-label light" text="Current Stock:" />
            <Label fx:id="currentStockLabel" styleClass="toolbar-value" text="0" />
            <Button fx:id="addSaleBtn" styleClass="btn-success" text="Add Sale" />
        </HBox>

        
        <VBox prefWidth="780.0" styleClass="table-card panel-card">
            <TableView fx:id="salesTable" prefHeight="300.0" prefWidth="780.0" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="saleIdColumn" prefWidth="100.0" text="Sale ID" />
                    <TableColumn fx:id="productNameColumn" prefWidth="300.0" text="Product Name" />
                    <TableColumn fx:id="quantitySoldColumn" prefWidth="100.0" text="Quantity" />
                    <TableColumn fx:id="priceColumn" prefWidth="150.0" text="Price" />
                    <TableColumn fx:id="totalColumn" prefWidth="150.0" text="Total" />
                </columns>
            </TableView>
        </VBox>

    </VBox>
</AnchorPane>
